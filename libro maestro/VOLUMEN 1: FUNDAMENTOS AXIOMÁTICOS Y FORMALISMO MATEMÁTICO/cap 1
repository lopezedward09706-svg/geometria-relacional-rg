Simula la auto-comparación del Silencio bajo perturbaciones aleatorias.
Verifica que ⟨0|0⟩/cos(Θ) ≈ 1 para pequeñas fluctuaciones.

USO: python rg_montecarlo_auto_comparacion.py
"""

import numpy as np

# Parámetros de simulación
N_SAMPLES = 100000   # Número de muestras Monte Carlo
N_NODOS = 19         # Tamaño de la red (Clúster 19)
SEED = 192657        # Semilla para reproducibilidad

rng = np.random.default_rng(SEED)

print("=" * 70)
print(f"  MONTE CARLO: AUTO-COMPARACIÓN DEL SILENCIO")
print(f"  Muestras: {N_SAMPLES:,} | Nodos: {N_NODOS} | Semilla: {SEED}")
print("=" * 70)

# ============================================================
# 1. Silencio Perfecto (θ = 0)
# ============================================================
print("\n[1] SILENCIO PERFECTO (θ = 0)")
valores_silencio = np.ones(N_SAMPLES)  # ⟨0|0⟩/cos(0) = 1/1 = 1
print(f"    ⟨0|0⟩/cos(0) = {np.mean(valores_silencio):.6f} (determinista, σ = 0)")
print(f"    El Silencio perfecto es exactamente 1.")

# ============================================================
# 2. Pequeñas Perturbaciones
# ============================================================
print("\n[2] PERTURBACIONES PEQUEÑAS (ε ≪ 1)")

for eps in [0.001, 0.01, 0.05, 0.1]:
    valores = np.zeros(N_SAMPLES)
    for i in range(N_SAMPLES):
        # Generar fases aleatorias con media 0 y desviación ε
        fases = rng.normal(0, eps, N_NODOS)
        Theta = np.mean(fases)  # Fase global
        P_val = np.cos(Theta)   # Operador de perturbación
        
        if abs(P_val) > 1e-10:
            valores[i] = 1.0 / P_val  # ⟨0|0⟩/cos(Θ)
        else:
            valores[i] = np.nan  # Evitar división por cero
    
    # Filtrar valores válidos
    valores_filtrados = valores[np.isfinite(valores)]
    media = np.mean(valores_filtrados)
    std = np.std(valores_filtrados)
    print(f"    ε = {eps:.3f}: media = {media:.6f}, std = {std:.6f}, "
          f"¿≈ 1? {'✓' if abs(media-1.0) < 0.01 else '✗ (desviación)'}")

# ============================================================
# 3. Ángulos Grandes (No Trivial)
# ============================================================
print("\n[3] ÁNGULOS GRANDES (θ > 0)")

for theta in [0.1, 0.5, 1.0, np.pi/4]:
    valores = np.zeros(N_SAMPLES)
    for i in range(N_SAMPLES):
        # Fases con media theta y pequeña dispersión
        fases = rng.normal(theta, 0.01, N_NODOS)
        Theta = np.mean(fases)
        P_val = np.cos(Theta)
        
        if abs(P_val) > 1e-10:
            valores[i] = 1.0 / P_val
        else:
            valores[i] = np.nan
    
    valores_filtrados = valores[np.isfinite(valores)]
    media = np.mean(valores_filtrados)
    std = np.std(valores_filtrados)
    print(f"    θ = {theta:.3f} rad: ⟨0|0⟩/cos(Θ) = {media:.4f} ± {std:.4f} ≠ 1")
    print(f"      (1/{np.cos(theta):.4f} = {1/np.cos(theta):.4f} esperado)")

# ============================================================
# 4. Análisis de Estabilidad
# ============================================================
print("\n[4] ANÁLISIS DE ESTABILIDAD")

# Calcular para qué ε la media se desvía más del 1%
epsilons = np.logspace(-3, 0, 20)
desviaciones = []

for eps in epsilons:
    valores = np.zeros(N_SAMPLES // 10)  # Menos muestras para velocidad
    for i in range(N_SAMPLES // 10):
        fases = rng.normal(0, eps, N_NODOS)
        Theta = np.mean(fases)
        P_val = np.cos(Theta)
        if abs(P_val) > 1e-10:
            valores[i] = 1.0 / P_val
        else:
            valores[i] = np.nan
    valores_filtrados = valores[np.isfinite(valores)]
    if len(valores_filtrados) > 0:
        desviaciones.append(abs(np.mean(valores_filtrados) - 1.0))
    else:
        desviaciones.append(np.inf)

# Encontrar ε donde la desviación supera 1%
umbral_1pct = None
for eps, desv in zip(epsilons, desviaciones):
    if desv > 0.01 and umbral_1pct is None:
        umbral_1pct = eps
        break

if umbral_1pct:
    print(f"    La auto-comparación se desvía >1% para ε > {umbral_1pct:.4f}")
else:
    print(f"    La auto-comparación es robusta para todo ε en el rango.")

# ============================================================
# Resumen
# ============================================================
print("\n" + "=" * 70)
print("  CONCLUSIÓN")
print("=" * 70)
print(f"  ✓ En el Silencio (θ = 0): auto-comparación = 1 (EXACTO)")
print(f"  ✓ Pequeñas perturbaciones (ε ≪ 1): valor ≈ 1 (ESTABLE)")
print(f"  ✓ Ángulos grandes (θ > 0): valor ≠ 1 (NO TRIVIAL)")
