13.3.1 500,000 Muestras

```python
#!/usr/bin/env python3
"""
MONTE CARLO DE ALTA PRECISIÓN — 500,000 MUESTRAS
Geometría Relacional (RG) — Volumen 4, Capítulo 13
"""

import numpy as np
import time

N_SAMPLES = 500000
SEED = 192657
rng = np.random.default_rng(SEED)

X_vals = np.array([0.5, 1.0, 1.5, 2.0, 3.0, 4.0, 6.0, 12.0, 19.0, 38.0, 57.0, 76.0, 95.0, 114.0])
E_media = np.zeros(len(X_vals))
E_std = np.zeros(len(X_vals))

print("="*70)
print(f"  MONTE CARLO DE ALTA PRECISIÓN — {N_SAMPLES:,} MUESTRAS")
print("="*70)
inicio = time.time()

for i, X in enumerate(X_vals):
    n_nodes = max(1, int(np.ceil(abs(X))))
    if n_nodes == 1:
        E_media[i], E_std[i] = 0, 0
        continue
    energias = np.zeros(N_SAMPLES)
    for s in range(N_SAMPLES):
        fases = rng.uniform(0, 2*np.pi, n_nodes)
        e = sum(1 - np.cos(fases[i] - fases[j]) for i in range(n_nodes) for j in range(i+1))
        if n_nodes > 1: e /= (n_nodes*(n_nodes-1)/2)
        energias[s] = e * abs(X)
    E_media[i] = np.mean(energias)
    E_std[i] = np.std(energias)

# Resultados
mask_var = (E_std > 1e-15) & (X_vals > 0.5)
q_est = np.mean(E_media[mask_var] / X_vals[mask_var])
q_std = np.std(E_media[mask_var] / X_vals[mask_var])
precision = 100*(1 - abs(q_est - 1.0))

print(f"\n  q estimado = {q_est:.8f} ± {q_std:.8f}")
print(f"  Precisión = {precision:.6f}%")
print(f"  Tiempo: {time.time()-inicio:.1f}s")

print(f"\n  {'X':<8} {'E_medida':<15} {'E_pred':<15} {'σ':<12} {'Error %':<10}")
print(f"  {'-'*60}")
for i, X in enumerate(X_vals):
    E_pred = X - 1
    error = abs(E_media[i]-E_pred)/abs(E_pred)*100 if abs(E_pred)>1e-10 else 0
    print(f"  {X:<8.1f} {E_media[i]:<15.8f} {E_pred:<15.8f} {E_std[i]:<12.8f} {error:<10.6f}%")
print("="*70)
