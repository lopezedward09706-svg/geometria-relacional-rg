#!/usr/bin/env python3
"""
SIMULACIÓN DEL HAMILTONIANO RG — DNLS
Geometría Relacional (RG) — Volumen 3, Capítulo 9
"""

import numpy as np
from scipy.sparse import csr_matrix
from scipy.sparse.linalg import eigsh
from scipy.integrate import solve_ivp
import matplotlib.pyplot as plt
import math, time

N = 19
DEUDA = 1.5; LAMBDA = 1/18; ETA = math.pi/57
GAMMA = DEUDA / N
DT = 0.01; T_MAX = 50.0

# Construir topología del Clúster 19
A = np.zeros((N, N))
centro = 0; anillo1 = list(range(1,7)); anillo2 = list(range(7,19))
for i in anillo1: A[centro,i] = LAMBDA; A[i,centro] = LAMBDA
for i in range(6):
    j = (i+1)%6; A[anillo1[i],anillo1[j]] = LAMBDA; A[anillo1[j],anillo1[i]] = LAMBDA
for i, idx in enumerate(anillo1):
    A[idx,anillo2[2*i]] = ETA; A[anillo2[2*i],idx] = ETA
    A[idx,anillo2[(2*i+1)%12]] = ETA; A[anillo2[(2*i+1)%12],idx] = ETA
for i in range(12):
    j = (i+1)%12; A[anillo2[i],anillo2[j]] = ETA; A[anillo2[j],anillo2[i]] = ETA

# Gap espectral
L = np.diag(np.sum(A, axis=1)) - A
vals = np.sort(eigsh(csr_matrix(L), k=10, which='SM')[0])
gap = vals[1] - vals[0]

# Simulación DNLS
def rhs(t, y):
    psi = y[:N] + 1j*y[N:]
    dpsi = -1j*(A@psi) - 1j*GAMMA*np.abs(psi)**2*psi
    return np.concatenate([np.real(dpsi), np.imag(dpsi)])

rng = np.random.default_rng(192657)
psi0 = np.ones(N, dtype=complex) + 0.01*rng.normal(N)
y0 = np.concatenate([np.real(psi0), np.imag(psi0)])
sol = solve_ivp(rhs, [0, T_MAX], y0, t_eval=np.arange(0, T_MAX, DT), method='RK45', rtol=1e-6, atol=1e-9)
t = sol.t
psi_hist = sol.y[:N,:] + 1j*sol.y[N:,:]
dens = np.abs(psi_hist)**2

print("="*60)
print("  SIMULACIÓN DEL HAMILTONIANO RG — CLÚSTER 19")
print("="*60)
print(f"  Gap espectral: λ₁ = {vals[1]:.6f} ≈ λ = {LAMBDA:.6f} {'✓' if abs(gap-LAMBDA)<0.01 else '✗'}")
print(f"  Energía inicial: {np.sum(np.abs(psi0)**2):.4f}")
print(f"  Energía final:   {np.sum(dens[:,-1]):.4f}")
print(f"  Solitones (|ψ|²>2): {np.sum(dens[:,-1]>2)}")
print(f"  Entropía inicial: {-np.sum((np.abs(psi0)**2/N)*np.log(np.abs(psi0)**2/N+1e-12)):.4f}")
p_final = dens[:,-1]/np.sum(dens[:,-1])
print(f"  Entropía final:   {-np.sum(p_final[p_final>1e-12]*np.log(p_final[p_final>1e-12])):.4f}")
print("="*60)

# Gráficos
fig, axes = plt.subplots(2, 3, figsize=(18, 12))
axes[0,0].plot(t, dens[0,:], 'r-', label='Centro')
axes[0,0].plot(t, np.mean(dens[1:7,:], axis=0), 'b-', label='Anillo 1')
axes[0,0].plot(t, np.mean(dens[7:19,:], axis=0), 'g-', label='Anillo 2')
axes[0,0].set_xlabel('t'); axes[0,0].set_ylabel('|ψ|²'); axes[0,0].set_title('Densidad de Fase'); axes[0,0].legend()

axes[0,1].plot(t, np.sum(dens, axis=0), 'm-')
axes[0,1].axhline(y=np.sum(np.abs(psi0)**2), color='gray', linestyle='--')
axes[0,1].set_xlabel('t'); axes[0,1].set_ylabel('Σ|ψ|²'); axes[0,1].set_title('Conservación de Energía')

entropia = [-np.sum((dens[:,i]/np.sum(dens[:,i])+1e-12)*np.log(dens[:,i]/np.sum(dens[:,i])+1e-12)) for i in range(len(t))]
axes[0,2].plot(t, entropia, 'k-')
axes[0,2].set_xlabel('t'); axes[0,2].set_ylabel('S(t)'); axes[0,2].set_title('Entropía de Shannon (Flecha del Tiempo)')

axes[1,0].stem(range(len(vals[:10])), vals[:10])
axes[1,0].axhline(y=LAMBDA, color='r', linestyle='--', label=f'λ=1/18')
axes[1,0].set_xlabel('Índice'); axes[1,0].set_ylabel('λ_i'); axes[1,0].set_title('Espectro del Laplaciano'); axes[1,0].legend()

axes[1,1].bar(range(N), dens[:,-1], color=['red' if d>2 else 'blue' for d in dens[:,-1]])
axes[1,1].axhline(y=2, color='red', linestyle='--', alpha=0.5)
axes[1,1].set_xlabel('Nodo'); axes[1,1].set_ylabel('|ψ|²'); axes[1,1].set_title('Densidad Final (Rojo=Solitones)')

n_solitones = [np.sum(dens[:,i]>2) for i in range(len(t))]
axes[1,2].plot(t, n_solitones, 'r-')
axes[1,2].set_xlabel('t'); axes[1,2].set_ylabel('Nº Solitones'); axes[1,2].set_title('Detección de Solitones')

plt.tight_layout(); plt.savefig('rg_hamiltonian_simulation.png', dpi=150)
plt.show()
