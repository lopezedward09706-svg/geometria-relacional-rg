import numpy as np
import math

DEUDA = 1.5; LAMBDA = 1/18; F_CONV = 0.3568; K_MASA = 0.262

def D(X, Y, Z):
    return np.pi ** ((X + Y - 2*Z) / 2)

def masa(x, y, z, Xr=1.0, Yr=0.5):
    if x==0 and y==0 and z==0: return 0.0
    w = max(x,y,z)/19.0
    Z = LAMBDA*(0.5 - w)
    Nn = math.gcd(math.gcd(x,y),z)
    if Nn==0: Nn=1
    return DEUDA*(2*w)**2/Nn * D(Xr,Yr,Z) * F_CONV * K_MASA

particulas = [
    ("Electrón", 1,6,12, 1.0,0.5, 0.511),
