#!/usr/bin/env python3
"""
TOPOLOGÍA DEL CLÚSTER 19 — VALIDACIÓN
Geometría Relacional (RG) — Volumen 2, Capítulo 5
"""

import numpy as np
from scipy.sparse import csr_matrix
from scipy.sparse.linalg import eigsh

N = 19
A = np.zeros((N, N))
centro = 0
anillo1 = list(range(1, 7))
anillo2 = list(range(7, 19))

# Conexiones
for i in anillo1:
    A[centro, i] = 1; A[i, centro] = 1
for i in range(6):
    j = (i+1)%6
    A[anillo1[i], anillo1[j]] = 1; A[anillo1[j], anillo1[i]] = 1
for i, idx in enumerate(anillo1):
    A[idx, anillo2[2*i]] = 1; A[anillo2[2*i], idx] = 1
    A[idx, anillo2[(2*i+1)%12]] = 1; A[anillo2[(2*i+1)%12], idx] = 1
for i in range(12):
    j = (i+1)%12
    A[anillo2[i], anillo2[j]] = 1; A[anillo2[j], anillo2[i]] = 1

# Análisis
grados = np.sum(A, axis=1).astype(int)
n_enlaces = int(np.sum(A)/2)

# Gap espectral
L = np.diag(grados) - A
vals = np.sort(eigsh(csr_matrix(L), k=10, which='SM')[0])

print("=" * 60)
print("  CLÚSTER 19 — TOPOLOGÍA Y GAP ESPECTRAL")
print("=" * 60)
print(f"  Nodos: {N}")
print(f"  Centro (grado): {grados[0]}")
print(f"  Anillo 1 (grado promedio): {np.mean(grados[1:7]):.1f}")
print(f"  Anillo 2 (grado promedio): {np.mean(grados[7:19]):.1f}")
print(f"  Enlaces activos: {n_enlaces}")
print(f"\n  Gap espectral λ₁ = {vals[1]:.6f}")
print(f"  λ = 1/18 = {1/18:.6f}")
print(f"  ¿Coinciden? {'✓' if abs(vals[1] - 1/18) < 1e-6 else '✗'}")
print("=" * 60)
